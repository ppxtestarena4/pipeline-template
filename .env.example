# ─── TechTCB Task Management System ──────────────────────────────────────────
# Copy this file to .env and fill in the values

# Database
POSTGRES_DB=techtcb
POSTGRES_USER=techtcb
POSTGRES_PASSWORD=change_me_in_production

# Backend
DATABASE_URL=postgresql://techtcb:change_me_in_production@localhost:5432/techtcb
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=80
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost

# AI (Anthropic Claude — for intake task extraction)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Development overrides (uncomment for local dev) ─────────────────────────
# DATABASE_URL=postgresql://techtcb:techtcb_secret@localhost:5432/techtcb
# NODE_ENV=development
# FRONTEND_URL=http://localhost:5173

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
  AI_AGENT
}

enum UserType {
  HUMAN
  AI_AGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  TESTING
  DONE
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Category {
  RUN
  CHANGE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_MENTIONED
  TASK_DUE
  TASK_STATUS_CHANGED
  COMMENT_ADDED
  REPORT_SUBMITTED
  REPORT_APPROVED
  INBOX_PROCESSED
  NEW_TASK_IN_BACKLOG
}

enum InboxStatus {
  PENDING
  PROCESSING
  EXTRACTED
  MODERATED
}

enum ExtractedTaskStatus {
  PENDING
  CONFIRMED
  EDITED
  DELETED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PARTIAL
  FAILED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String
  role          UserRole @default(EMPLOYEE)
  type          UserType @default(HUMAN)
  apiToken      String?  @unique
  managerId     String?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  manager       User?    @relation("UserManager", fields: [managerId], references: [id])
  directReports User[]   @relation("UserManager")

  ownedProjects    Project[]       @relation("ProjectOwner")
  projectMembers   ProjectMember[]
  assignedTasks    Task[]          @relation("TaskAssignee")
  createdTasks     Task[]          @relation("TaskCreator")
  comments         Comment[]
  notifications    Notification[]
  inboxItems       InboxItem[]
  reports          Report[]        @relation("ReportUser")
  managedReports   Report[]        @relation("ReportManager")
  goals            Goal[]          @relation("GoalUser")
  managedGoals     Goal[]          @relation("GoalManager")
  taskHistory      TaskHistory[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  tasks       Task[]
  inboxItems  InboxItem[]
}

model ProjectMember {
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  projectId   String
  assigneeId  String?
  creatorId   String
  status      TaskStatus @default(BACKLOG)
  priority    Priority   @default(MEDIUM)
  category    Category   @default(RUN)
  dueDate     DateTime?
  parentId    String?
  completedAt DateTime?
  labels      String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project         Project         @relation(fields: [projectId], references: [id])
  assignee        User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator         User            @relation("TaskCreator", fields: [creatorId], references: [id])
  parent          Task?           @relation("Subtasks", fields: [parentId], references: [id])
  subtasks        Task[]          @relation("Subtasks")
  comments        Comment[]
  checklistItems  ChecklistItem[]
  history         TaskHistory[]
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  taskId    String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InboxItem {
  id           String      @id @default(cuid())
  userId       String
  projectId    String?
  fileName     String?
  fileUrl      String?
  fileType     String?
  originalText String?
  transcript   String?
  meetingNotes String?
  status       InboxStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  project        Project?        @relation(fields: [projectId], references: [id])
  extractedTasks ExtractedTask[]
}

model ExtractedTask {
  id                  String              @id @default(cuid())
  inboxItemId         String
  title               String
  description         String?
  suggestedAssigneeId String?
  suggestedProjectId  String?
  dueDate             DateTime?
  category            Category            @default(RUN)
  priority            Priority            @default(MEDIUM)
  status              ExtractedTaskStatus @default(PENDING)
  taskId              String?
  createdAt           DateTime            @default(now())

  inboxItem InboxItem @relation(fields: [inboxItemId], references: [id], onDelete: Cascade)
}

model Report {
  id              String    @id @default(cuid())
  userId          String
  managerId       String
  period          String
  startDate       DateTime
  endDate         DateTime
  comment         String?
  approved        Boolean   @default(false)
  approverComment String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User @relation("ReportUser", fields: [userId], references: [id])
  manager User @relation("ReportManager", fields: [managerId], references: [id])
}

model Goal {
  id             String     @id @default(cuid())
  userId         String
  managerId      String
  title          String
  description    String?
  weekStart      DateTime
  weekEnd        DateTime
  status         GoalStatus @default(NOT_STARTED)
  relatedTaskIds String[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user    User @relation("GoalUser", fields: [userId], references: [id])
  manager User @relation("GoalManager", fields: [managerId], references: [id])
}
